# Google API Keys and Service Accounts
GOOGLE_API_KEY="your_gemini_api_key_here"
CIVIC_INFO_API_KEY="your_civic_info_key_here"

# Path to your Google Cloud Service Account JSON for Vertex AI, Translation, and Wallet
